{
  "name": "cruizn-clean-deploy",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "scripts": {
    "dev": "pnpm --dir apps/web dev",
    "build": "pnpm --dir apps/web build",
    "start": "pnpm --dir apps/web start",
    "vercel-build": "pnpm --dir apps/web build",
    "env:check:web": "pnpm --dir apps/web env:check",
    "lint:web": "pnpm --dir apps/web lint",
