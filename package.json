    "quality:web": "pnpm --dir apps/web quality",
    "quality": "pnpm quality:web"
  },
  "engines": {
    "node": ">=22.0.0"
  },
  "dependencies": {
    "next": "14.2.35",
    "react": "18.3.1",
    "react-dom": "18.3.1"
  },
  "pnpm": {
