  },
  "dependencies": {
    "clsx": "2.1.1",
    "lucide-react": "^1.11.0",
    "next": "14.2.35",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "sharp": "^0.34.5",
    "tailwind-merge": "3.5.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@types/node": "20.16.1",
    "@types/react": "18.3.5",
    "@types/react-dom": "18.3.0",
    "@varlock/nextjs-integration": "latest",
    "autoprefixer": "10.5.0",
    "eslint": "^8.57.0",
    "eslint-config-next": "^14.2.35",
    "postcss": "8.5.10",
    "tailwindcss": "3.4.10",
    "typescript": "5.5.4",
    "varlock": "latest"
  },
  "overrides": {
    "next": {
      "@next/env": "npm:@varlock/nextjs-integration"
