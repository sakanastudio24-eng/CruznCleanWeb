{
  "name": "cruz-n-clean-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "varlock run -- next dev",
    "dev:raw": "next dev",
    "build": "varlock run -- next build",
    "build:raw": "next build",
    "start": "varlock run -- next start",
    "start:raw": "next start",
    "lint": "varlock run -- next lint",
