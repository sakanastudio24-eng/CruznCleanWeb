{
  "name": "cruz-n-clean-web",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "npm exec -- varlock run -- next dev",
    "dev:raw": "next dev",
    "build": "npm exec -- varlock run -- next build",
    "build:raw": "next build",
    "start": "npm exec -- varlock run -- next start",
    "start:raw": "next start",
    "lint": "npm exec -- varlock run -- next lint",
    "typecheck": "tsc --noEmit",
    "env:check": "npm exec -- varlock load",
    "quality": "npm run env:check && npm run lint && npm run typecheck && npm run build"
  },
  "dependencies": {
    "clsx": "2.1.1",
    "lucide-react": "^0.460.0",
    "next": "14.2.35",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "tailwind-merge": "2.5.2"
  },
  "devDependencies": {
    "@types/node": "20.16.1",
    "@types/react": "18.3.5",
    "@types/react-dom": "18.3.0",
    "@varlock/nextjs-integration": "latest",
    "autoprefixer": "10.4.20",
    "eslint": "^9.0.0",
    "eslint-config-next": "^14.2.35",
    "postcss": "8.4.45",
    "tailwindcss": "3.4.10",
    "typescript": "5.5.4",
    "varlock": "latest"
  },
  "overrides": {
    "next": {
      "@next/env": "npm:@varlock/nextjs-integration"
    }
  },
  "engines": {
    "node": "22.x"
  }
}
